# ============================================================
# ANNOTATION PLATFORM - Configuration exemple
# ============================================================
# Copiez ce fichier en application.properties et modifiez les valeurs

spring.application.name=annotation-platform
server.port=8080

# ============================================================
# BASE DE DONNEES
# ============================================================
# H2 Database
spring.datasource.url=jdbc:h2:file:./data/annotation_platform;DB_CLOSE_DELAY=-1
spring.datasource.driverClassName=org.h2.Driver
spring.datasource.username=sa
spring.datasource.password=

# MariaDB (pour le développement local avec Docker)
# spring.datasource.url=jdbc:mariadb://localhost:3306/annotation_platform
# spring.datasource.username=root
# spring.datasource.password=root
# spring.datasource.driver-class-name=org.mariadb.jdbc.Driver

# ============================================================
# JPA
# ============================================================
spring.jpa.database-platform=org.hibernate.dialect.H2Dialect
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true

# ============================================================
# H2 Console
# ============================================================
spring.h2.console.enabled=true
spring.h2.console.path=/h2-console

# ============================================================
# THYMELEAF
# ============================================================
spring.thymeleaf.cache=false

# ============================================================
# SECURITY
# ============================================================
logging.level.org.springframework.security=INFO